{
  "compilerOptions": {
    "strict": true,
    "target": "ES2023",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "references": [
    { "path": "packages/contracts" },
    { "path": "packages/akidb" },
    { "path": "packages/fabric-ingest" }
  ],
  "files": []
}

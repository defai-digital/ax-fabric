{
  "compilerOptions": {
    "strict": true,
    "target": "ES2023",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}

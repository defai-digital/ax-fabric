{
  "name": "ax-fabric",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "vitest",
    "lint": "pnpm -r lint --if-present",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean --if-present && cargo clean --manifest-path packages/akidb-native/Cargo.toml 2>/dev/null; true",
    "ci:build": "pnpm install --frozen-lockfile && pnpm build",
    "release": "pnpm clean && pnpm build && pnpm test && pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
